{
  "version": 2,
  "public": true,
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/tracks/(.*)", "dest": "/tracks/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
